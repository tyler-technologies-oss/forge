{
  "name": "@tylertech/forge-tailwind",
  "version": "0.0.0",
  "description": "Tailwind CSS theme using Forge design tokens",
  "license": "Apache-2.0",
  "author": "Tyler Technologies, Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/tyler-technologies-oss/forge.git",
    "directory": "packages/forge-tailwind"
  },
  "type": "module",
  "exports": {
    ".": "./dist/forge-theme.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "sass css/forge-theme.scss dist/forge-theme.css --load-path=node_modules"
  },
  "dependencies": {
    "@tylertech/forge": "workspace:"
  },
  "devDependencies": {
    "sass": "catalog:"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
