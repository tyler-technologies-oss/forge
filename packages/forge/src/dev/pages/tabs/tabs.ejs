<div class="tabs-demo-container">
  <forge-tab-bar id="tabs-demo" active-tab="0">
    <forge-tab id="tab-1" name="one" aria-controls="panel-1">Tab one</forge-tab>
    <forge-tab id="tab-2" name="two" aria-controls="panel-2">Tab two</forge-tab>
    <forge-tab id="tab-3" name="three" aria-controls="panel-3">Tab three</forge-tab>
    <forge-tab id="tab-4" name="four" aria-controls="panel-4">Tab four</forge-tab>
  </forge-tab-bar>
  <forge-view-switcher id="tab-panel" index="0" animation-type="slide">
    <forge-view>
      <div id="panel-1" role="tabpanel" aria-labelledby="tab-1" class="tab-content">Content for tab index: 1</div>
    </forge-view>
    <forge-view>
      <div id="panel-2" role="tabpanel" aria-labelledby="tab-2" class="tab-content">Content for tab index: 2</div>
    </forge-view>
    <forge-view>
      <div id="panel-3" role="tabpanel" aria-labelledby="tab-3" class="tab-content">Content for tab index: 3</div>
    </forge-view>
    <forge-view>
      <div id="panel-4" role="tabpanel" aria-labelledby="tab-4" class="tab-content">Content for tab index: 4</div>
    </forge-view>
  </forge-view-switcher>
</div>

