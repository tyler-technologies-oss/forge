{
  "name": "blocks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm clean && pnpm build:blocks && pnpm build:assets",
    "build:blocks": "tsx src/scripts/build-blocks.ts",
    "build:assets": "vite build --config vite-assets.config.ts",
    "clean": "rimraf dist",
    "screenshots": "pnpm generate-screenshots",
    "generate-manifest": "tsx src/scripts/generate-manifest.ts",
    "generate-screenshots": "tsx src/scripts/generate-screenshots.ts"
  },
  "dependencies": {
    "@tylertech/forge": "workspace:*",
    "@tylertech/forge-extended": "^1.6.2",
    "@tylertech/forge-tailwind": "workspace:*",
    "@tylertech/tyler-icons": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/node": "catalog:",
    "glob": "catalog:",
    "handlebars": "^4.7.8",
    "playwright": "catalog:",
    "rimraf": "catalog:",
    "sass": "catalog:",
    "sharp": "^0.34.5",
    "tailwindcss": "catalog:",
    "tsx": "^4.19.0",
    "typescript": "~5.8.0",
    "vite": "catalog:"
  }
}
