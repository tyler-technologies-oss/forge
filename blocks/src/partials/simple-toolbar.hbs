<forge-toolbar>
  <h2 slot="start" class="text-heading3">{{#if title}}{{title}}{{else}}Page Title{{/if}}</h2>
  <div slot="end" class="flex gap-xsmall">
    <forge-icon-button density="medium" aria-label="Notifications">
      <forge-icon name="notifications"></forge-icon>
    </forge-icon-button>
    <forge-icon-button density="medium" aria-label="Settings">
      <forge-icon name="settings"></forge-icon>
    </forge-icon-button>
    <forge-icon-button density="medium" aria-label="More options">
      <forge-icon name="more_vert"></forge-icon>
    </forge-icon-button>
  </div>
</forge-toolbar>