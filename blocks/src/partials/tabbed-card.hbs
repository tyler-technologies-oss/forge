<forge-card no-padding class="tabbed-card">
  <div class="flex justify-between items-start p-medium pb-0">
    <div class="flex flex-col gap-xxxsmall">
      <span class="text-overline">Server Details</span>
      <div class="flex items-center gap-xsmall">
        <h2 class="text-heading3">Atlassian MCP</h2>
        <forge-icon name="verified" style="color: var(--forge-theme-primary);"></forge-icon>
      </div>
    </div>
    <forge-icon-button aria-label="More options" density="medium">
      <forge-icon name="more_vert"></forge-icon>
    </forge-icon-button>
  </div>
  <forge-tab-bar active-tab="0" clustered class="px-medium">
    <forge-tab>Overview</forge-tab>
    <forge-tab>Resources</forge-tab>
    <forge-tab>Tools</forge-tab>
    <forge-tab>Prompts</forge-tab>
  </forge-tab-bar>
  <forge-view-switcher>
    <forge-view>
      <div class="p-medium">
        <forge-card class="tonal-card">
          <div class="flex flex-col gap-medium">
            <forge-label-value>
              <span slot="label">Description</span>
              <span slot="value">Tyler Agency Intelligence MCP server providing user management, group management, and task administration tools for the Agency Intelligence platform.</span>
            </forge-label-value>
            <forge-label-value>
              <span slot="label">Version</span>
              <span slot="value">26.0.0</span>
            </forge-label-value>
            <forge-label-value>
              <span slot="label">Forwarded Headers</span>
              <div slot="value" class="flex flex-wrap gap-xsmall">
                <forge-chip dense>x-correlation-id</forge-chip>
                <forge-chip dense>x-session-id</forge-chip>
                <forge-chip dense>x-user-email</forge-chip>
                <forge-chip dense>x-user-email-sig</forge-chip>
              </div>
            </forge-label-value>
            <forge-label-value>
              <span slot="label">Authentication type</span>
              <span slot="value" class="font-mono">API_KEY</span>
            </forge-label-value>
          </div>
        </forge-card>
      </div>
    </forge-view>
    <forge-view>
      <div class="p-medium">
        <p class="text-body1">Resources content goes here.</p>
      </div>
    </forge-view>
    <forge-view>
      <div class="p-medium">
        <p class="text-body1">Tools content goes here.</p>
      </div>
    </forge-view>
    <forge-view>
      <div class="p-medium">
        <p class="text-body1">Prompts content goes here.</p>
      </div>
    </forge-view>
  </forge-view-switcher>
</forge-card>

<script>
  (function () {
    document.querySelectorAll('.tabbed-card').forEach((card) => {
      if (card.dataset.initialized) return;
      card.dataset.initialized = 'true';

      const tabBar = card.querySelector('forge-tab-bar');
      const viewSwitcher = card.querySelector('forge-view-switcher');

      tabBar.addEventListener('forge-tab-bar-change', (event) => {
        viewSwitcher.index = event.detail.index;
      });
    });
  })();
</script>
