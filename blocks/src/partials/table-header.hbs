<forge-toolbar>
  <h2 slot="start" class="text-heading3">{{#if title}}{{title}}{{else}}Table Title{{/if}}</h2>
  <div slot="end" class="flex gap-xsmall">
    <forge-icon-button density="medium" aria-label="{{#if icon1Label}}{{icon1Label}}{{else}}Filter{{/if}}">
      <forge-icon name="{{#if icon1}}{{icon1}}{{else}}filter_list{{/if}}"></forge-icon>
    </forge-icon-button>
    <forge-icon-button density="medium" aria-label="{{#if icon2Label}}{{icon2Label}}{{else}}Export{{/if}}">
      <forge-icon name="{{#if icon2}}{{icon2}}{{else}}download{{/if}}"></forge-icon>
    </forge-icon-button>
    <forge-icon-button density="medium" aria-label="{{#if icon3Label}}{{icon3Label}}{{else}}More options{{/if}}">
      <forge-icon name="{{#if icon3}}{{icon3}}{{else}}more_vert{{/if}}"></forge-icon>
    </forge-icon-button>
  </div>
</forge-toolbar>
